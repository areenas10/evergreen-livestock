<%- include('../partials/header') %>

<style>
  .auth-fullscreen {
    min-height:100vh; display:flex; justify-content:center; align-items:center;
    background:linear-gradient(rgba(13,31,27,0.6),rgba(13,31,27,0.7)),url('/images/hero_banner.png');
    background-size:cover; background-position:center; background-attachment:fixed;
    padding:2rem; position:relative; overflow:hidden;
  }
  .auth-glass-card {
    background:rgba(255,255,255,0.88); backdrop-filter:blur(20px);
    -webkit-backdrop-filter:blur(20px); border:1px solid rgba(255,255,255,0.5);
    border-radius:20px; padding:2.2rem; width:100%; max-width:450px;
    box-shadow:0 25px 50px rgba(0,0,0,0.2); position:relative; z-index:10;
    animation:authFadeUp 0.8s cubic-bezier(0.165,0.84,0.44,1) forwards;
    opacity:0; transform:translateY(20px);
  }
  @keyframes authFadeUp { to { opacity:1; transform:translateY(0); } }
  .auth-logo-leaf {
    width:50px; height:50px; background:linear-gradient(135deg,#1a3c34,#27ae60);
    border-radius:50%; display:flex; align-items:center; justify-content:center;
    font-size:1.5rem; margin:0 auto 0.8rem auto; box-shadow:0 5px 15px rgba(26,60,52,0.25);
  }
  .auth-glass-card h2 { font-size:1.7rem; font-weight:800; color:#1a3c34; text-align:center; margin-bottom:0.3rem; }
  .auth-subtitle { text-align:center; color:#5c6b6b; font-size:0.9rem; margin-bottom:1.5rem; }
  .auth-success {
    background:rgba(39,174,96,0.1); border:1px solid rgba(39,174,96,0.35);
    color:#1e7e34; padding:1rem; border-radius:12px;
    font-size:0.88rem; font-weight:600; margin-bottom:1rem; text-align:center; line-height:1.6;
  }
  .auth-error {
    background:rgba(231,76,60,0.1); border:1px solid rgba(231,76,60,0.3);
    color:#c0392b; padding:0.8rem; border-radius:10px;
    font-size:0.85rem; margin-bottom:1rem; font-weight:600; text-align:center;
  }
  .auth-input-group { margin-bottom:1rem; }
  .auth-input-group label {
    font-size:0.85rem; font-weight:800; color:#1a3c34;
    display:block; margin-bottom:0.3rem; padding-left:0.2rem;
  }
  .auth-input-group input {
    width:100%; padding:0.9rem 1rem; background:rgba(255,255,255,0.9);
    border:2px solid transparent; border-radius:12px; font-size:0.95rem;
    font-family:'Outfit',sans-serif; color:#2c3333; transition:all 0.3s ease; box-sizing:border-box;
  }
  .auth-input-group input:focus {
    outline:none; border-color:#c5e063; background:white;
    box-shadow:0 0 0 5px rgba(197,224,99,0.2);
  }
  .strength-bar-wrap { height:5px; background:#eee; border-radius:10px; margin-top:8px; }
  .strength-bar { height:100%; border-radius:10px; width:0; transition:width 0.4s ease, background 0.4s ease; }
  .strength-label { font-size:0.75rem; font-weight:700; margin-top:4px; padding-left:2px; }
  .auth-submit {
    width:100%; padding:1rem; background:linear-gradient(135deg,#1a3c34,#2d6a55);
    color:white; border:none; border-radius:12px; font-size:1rem; font-weight:800;
    font-family:'Outfit',sans-serif; cursor:pointer; transition:all 0.3s ease;
    margin-top:0.5rem; box-shadow:0 8px 15px rgba(26,60,52,0.15);
  }
  .auth-submit:hover { transform:translateY(-2px); box-shadow:0 12px 20px rgba(26,60,52,0.25); }
  .auth-links { text-align:center; margin-top:1.5rem; font-size:0.9rem; color:#5c6b6b; }
  .auth-links a { color:#1a3c34; font-weight:800; text-decoration:none; }
</style>

<div class="auth-fullscreen">
  <div class="auth-glass-card">
    <div class="auth-logo-leaf">🌿</div>
    <h2>Reset Password</h2>
    <p class="auth-subtitle">Choose a strong new password for your account.</p>

    <% if (success) { %>
      <div class="auth-success">✅ <%= success %></div>
      <div class="auth-links"><p><a href="/auth/login">→ Go to Login</a></p></div>
    <% } else { %>
      <% if (error) { %>
        <div class="auth-error"><%= error %></div>
      <% } %>
      <form action="/auth/reset-password" method="POST">
        <div class="auth-input-group">
          <label for="password">New Password</label>
          <input type="password" id="password" name="password" minlength="6" placeholder="Minimum 6 characters" required oninput="checkStrength(this.value)">
          <div class="strength-bar-wrap"><div class="strength-bar" id="strengthBar"></div></div>
          <div class="strength-label" id="strengthLabel" style="color:#aaa;">Enter a password</div>
        </div>
        <div class="auth-input-group">
          <label for="confirmPassword">Confirm Password</label>
          <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Repeat your password" required>
        </div>
        <button type="submit" class="auth-submit">Set New Password</button>
      </form>
      <div class="auth-links">
        <p><a href="/auth/login">Back to Login</a></p>
      </div>
    <% } %>
  </div>
</div>

<script>
function checkStrength(pw) {
    const bar = document.getElementById('strengthBar');
    const label = document.getElementById('strengthLabel');
    let score = 0;
    if (pw.length >= 6) score++;
    if (pw.length >= 10) score++;
    if (/[A-Z]/.test(pw)) score++;
    if (/[0-9]/.test(pw)) score++;
    if (/[^A-Za-z0-9]/.test(pw)) score++;

    const levels = [
        { w:'10%',  bg:'#e74c3c', text:'Very Weak',  color:'#e74c3c' },
        { w:'30%',  bg:'#e67e22', text:'Weak',        color:'#e67e22' },
        { w:'55%',  bg:'#f1c40f', text:'Fair',        color:'#c9a800' },
        { w:'78%',  bg:'#2ecc71', text:'Good',        color:'#27ae60' },
        { w:'100%', bg:'#27ae60', text:'Strong 💪',   color:'#1a7d45' }
    ];
    const lvl = levels[Math.min(score, 4)];
    if (pw.length === 0) { bar.style.width='0'; label.textContent='Enter a password'; label.style.color='#aaa'; return; }
    bar.style.width = lvl.w;
    bar.style.background = lvl.bg;
    label.textContent = lvl.text;
    label.style.color = lvl.color;
}
</script>

<%- include('../partials/footer') %>
