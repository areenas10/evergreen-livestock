<%- include('../partials/header') %>

<section class="container" style="min-height: 60vh; display: flex; justify-content: center; align-items: center;">
    <div class="form-container" style="max-width: 500px; width: 100%;">
        <h2 style="text-align: center; margin-bottom: 1.5rem; color: var(--dark-green);">Make Payment</h2>
        
        <div style="background: var(--light-green); padding: 1rem; border-radius: 4px; margin-bottom: 1.5rem; text-align: center;">
            <strong>Order Total: $<%= parseFloat(order.total_amount).toFixed(2) %></strong>
            <br>
            <span style="font-size: 0.9rem;">Delivery: <%= order.delivery_method %></span>
        </div>
        
        <form action="/user/payment/<%= order.id %>" method="POST">
            <div class="form-group">
                <label>Select Payment Method</label>
                <select name="paymentMethod" required>
                    <% if (order.deliveryMethod === 'Home Delivery') { %>
                        <option value="Advance Payment">Advance Payment (Online/Card)</option>
                    <% } else { %>
                        <option value="Cash on Delivery">Pay at Pickup</option>
                        <option value="Online">Pay Online Now</option>
                    <% } %>
                </select>
            </div>
            
            <button type="submit" class="btn" style="width: 100%; margin-top: 1rem;">Confirm Payment</button>
        </form>
    </div>
</section>

<%- include('../partials/footer') %>
