<%- include('../partials/header') %>

<div class="container">
    <div style="text-align: center; margin-bottom: 4rem;">
        <h1 class="reveal" style="font-size: 3.5rem; font-weight: 800; color: var(--primary-green); letter-spacing: -2px; line-height: 1;">Marketplace</h1>
        <p class="reveal" style="color: var(--text-muted); font-size: 1.1rem; margin-top: 1rem; animation-delay: 0.1s;">Discover ethically-raised livestock and premium farm essentials.</p>
    </div>

    <div class="search-filter-section reveal" style="animation-delay: 0.2s;">
        <form action="/products" method="GET" class="search-container">
            <i class="search-icon">🔍</i>
            <input type="text" name="search" placeholder="Search for animals or farm products..." value="<%= searchQuery %>">
            <input type="hidden" name="category" value="<%= selectedCategory %>">
            <button type="submit" class="btn btn-ripple">Discover</button>
        </form>

        <div class="filter-pills">
            <% ['All', 'Goats', 'Ducks', 'Rabbits', 'Pigeons', 'Food items'].forEach(cat => { %>
                <a href="/products?category=<%= cat %><%= searchQuery ? '&search=' + searchQuery : '' %>" 
                   class="filter-pill <%= selectedCategory === cat ? 'active' : '' %>">
                   <%= cat %>
                </a>
            <% }) %>
        </div>
    </div>
    
    <div class="farm-grid reveal" style="animation-delay: 0.3s;">
        <% if (products && products.length > 0) { %>
            <% products.forEach(product => { %>
                <div class="farm-card">
                    <div class="farm-badge"><%= product.category %></div>
                    <div class="farm-card-img" style="height: 210px;">
                        <a href="/product/<%= product._id %>" id="cardImgLink_<%= product._id %>">
                            <img src="<%= product.image || '/images/placeholder.jpg' %>" alt="<%= product.name %>" onerror="this.src='/images/placeholder.jpg'; this.style.opacity='0.1';">
                        </a>
                    </div>
                    <div class="farm-card-details" style="padding: 1.2rem; display: flex; flex-direction: column; justify-content: space-between; min-height: 200px;">
                        <div>
                            <div class="farm-card-cat" style="color: var(--text-muted); font-size: 0.78rem; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px;"><%= product.category %> • Local Farm</div>
                            <h3 class="farm-card-title" style="margin: 0.4rem 0 0.8rem 0; font-size: 1.15rem; font-weight: 700; color: var(--primary-green);"><%= product.name %></h3>
                            
                            <!-- Dropdown for Weight and Money -->
                            <% if (product.weightVariants && product.weightVariants.length > 0) { %>
                                <div style="margin-bottom: 1rem;">
                                    <label style="font-size: 0.72rem; font-weight: 800; color: var(--text-muted); text-transform: uppercase; display: block; margin-bottom: 0.25rem; letter-spacing: 0.5px;">⚖️ Weight Selection</label>
                                    <select class="card-variant-select" onchange="updateCardVariant(this, '<%= product._id %>')" 
                                            style="width: 100%; padding: 0.55rem 0.8rem; border: 1.5px solid #cce2d0; border-radius: 10px; font-weight: 700; color: var(--primary-green); background: #fff; cursor: pointer; font-size: 0.85rem; outline: none; transition: border-color 0.2s;">
                                        <% product.weightVariants.forEach((v, idx) => { %>
                                            <option value="<%= idx %>" data-price="<%= v.price %>" data-weight="<%= v.weight %>">
                                                <%= v.weight %> — ₹<%= parseFloat(v.price).toLocaleString('en-IN') %>
                                            </option>
                                        <% }) %>
                                    </select>
                                </div>
                            <% } else { %>
                                <div class="farm-card-cat" style="font-weight: 700; color: var(--primary-green); margin-bottom: 1rem; font-size: 0.85rem;">
                                    ⚖️ <%= product.weight %>
                                </div>
                            <% } %>
                        </div>
                        
                        <div>
                            <div class="farm-card-price-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                                <span class="farm-price" id="cardPrice_<%= product._id %>" style="font-size: 1.35rem; font-weight: 800; color: var(--primary-green);">
                                    ₹<%= parseFloat(product.weightVariants && product.weightVariants.length > 0 ? product.weightVariants[0].price : product.price).toLocaleString('en-IN') %>
                                </span>
                            </div>
                            
                            <a id="cardLink_<%= product._id %>" href="/product/<%= product._id %>?variant=0" class="btn btn-ripple" style="width: 100%; border-radius: 12px; font-size: 0.8rem; text-align: center; display: block; padding: 0.6rem 1rem;">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div style="grid-column: 1 / -1; text-align: center; padding: 6rem 2rem; background: var(--white); border-radius: 32px; box-shadow: var(--shadow-soft);">
                <div style="font-size: 4rem; margin-bottom: 1.5rem; opacity: 0.2;">📦</div>
                <h2 style="color: var(--primary-green); font-weight: 800;">Harvest Not Found</h2>
                <p style="color: var(--text-muted); margin-bottom: 2rem;">We couldn't find items matching your discovery criteria.</p>
                <a href="/products" class="btn btn-ripple">Refreshen Catalog</a>
            </div>
        <% } %>
    </div>
</div>

<script>
function updateCardVariant(selectEl, productId) {
    const selectedOpt = selectEl.options[selectEl.selectedIndex];
    const price = parseFloat(selectedOpt.getAttribute('data-price')) || 0;
    
    // Update price element
    const priceDisplay = document.getElementById('cardPrice_' + productId);
    if (priceDisplay) {
        priceDisplay.textContent = '₹' + price.toLocaleString('en-IN');
    }
    
    // Update View Details link
    const detailsLink = document.getElementById('cardLink_' + productId);
    if (detailsLink) {
        detailsLink.href = '/product/' + productId + '?variant=' + selectEl.value;
    }
    
    // Update image link
    const imgLink = document.getElementById('cardImgLink_' + productId);
    if (imgLink) {
        imgLink.href = '/product/' + productId + '?variant=' + selectEl.value;
    }
}
</script>

<%- include('../partials/footer') %>
