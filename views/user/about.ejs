<section class="container scroll-reveal" style="background-color: var(--white); padding: 5rem; border-radius: 24px; margin-top: 4rem; min-height: 50vh; box-shadow: var(--shadow-soft);">
    <h1 style="text-align: center; margin-bottom: 3rem; color: var(--primary-green); font-size: 3rem; font-weight: 800;">About Evergreen Livestock</h1>
    
    <div style="display: flex; flex-direction: column; gap: 3rem; align-items: center; text-align: center;">
        <div style="border-radius: 24px; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.15);">
