<%- include('../partials/header') %>



<section class="hero parallax-hero">
    <div class="parallax-bg" id="heroBg"></div>
    <div class="hero-content" id="heroContent">
        <div class="scroll-reveal" style="background: rgba(255,255,255,0.1); padding: 0.5rem 1.2rem; border-radius: 100px; display: inline-block; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 1.5rem; backdrop-filter: blur(5px); transition-delay: 0.1s;">
            <span style="display:inline-block; animation: pulseGlow 2s infinite;">🌿</span> Welcome to the
        </div>
        <h1 class="scroll-reveal" style="transition-delay: 0.2s; font-size: clamp(4rem, 12vw, 8rem); margin-bottom: 0.5rem; letter-spacing: 2px;">EVERLIV</h1>
        <h2 class="scroll-reveal gradient-text" style="transition-delay: 0.3s; font-size: clamp(1.4rem, 3vw, 2.2rem); font-weight: 700; margin-bottom: 2rem; display: block; max-width: 800px; margin-left: auto; margin-right: auto;">Evergreen Natural Farming Livestock</h2>
        <p class="scroll-reveal" style="transition-delay: 0.4s;">Experience the finest selection of organically-raised livestock and premium animal feed, delivered with care from our farm to your home.</p>
        
        <div class="scroll-reveal" style="display: flex; gap: 1.5rem; justify-content: center; transition-delay: 0.6s;">
            <% if (!user) { %>
                <a href="/products" class="btn btn-ripple">Start Exploring</a>
            <% } else { %>
                <a href="/products" class="btn btn-ripple">Explore Marketplace</a>
                <a href="/user/dashboard" class="btn btn-secondary btn-ripple">My Dashboard</a>
            <% } %>
        </div>
    </div>
</section>

<section class="container" style="margin-top: 2rem; position: relative; z-index: 10;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
        
        <div class="glass scroll-reveal" style="padding: 2.5rem; border-radius: 24px; transition-delay: 0.1s;">
            <div>
                <div style="font-size: 3rem; margin-bottom: 1rem; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));">🐏</div>
                <h3 style="color: var(--primary-green); margin-bottom: 1rem; font-size: 1.4rem;">Ethical Breeding</h3>
                <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.6;">Our livestock is raised in a stress-free environment, following the highest animal welfare standards.</p>
            </div>
        </div>
        
        <div class="glass scroll-reveal" style="padding: 2.5rem; border-radius: 24px; transition-delay: 0.3s;">
            <div>
                <div style="font-size: 3rem; margin-bottom: 1rem; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));">🌽</div>
                <h3 style="color: var(--primary-green); margin-bottom: 1rem; font-size: 1.4rem;">Organic Feed</h3>
                <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.6;">100% natural, pesticide-free nutrition ensures our animals grow strong and healthy.</p>
            </div>
        </div>
        
        <div class="glass scroll-reveal" style="padding: 2.5rem; border-radius: 24px; transition-delay: 0.5s;">
            <div>
                <div style="font-size: 3rem; margin-bottom: 1rem; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));">🏡</div>
                <h3 style="color: var(--primary-green); margin-bottom: 1rem; font-size: 1.4rem;">Direct Delivery</h3>
                <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.6;">From our farm gate to your location, we handle transportation with professional care.</p>
            </div>
        </div>

    </div>
</section>

<section class="container scroll-reveal" style="background-color: var(--white); padding: 5rem; border-radius: 40px; margin-top: 6rem; margin-bottom: 6rem; box-shadow: var(--shadow-hover); position: relative; overflow: hidden; transition-delay: 0.2s;">
    <!-- Abstract gradient blob -->
    <div style="position: absolute; top: -100px; right: -50px; width: 300px; height: 300px; background: radial-gradient(circle, rgba(197, 224, 99, 0.2) 0%, rgba(255,255,255,0) 70%); border-radius: 50%; pointer-events: none;"></div>
    
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; position: relative; z-index: 2;">
        <div>
            <h2 style="margin-bottom: 1.5rem; color: var(--primary-green); font-size: 3rem; line-height: 1.1; font-weight: 800;">Our Commitment to <br><span class="gradient-text">Natural Harmony</span></h2>
            <p style="margin-bottom: 2rem; color: var(--text-muted); font-size: 1.15rem; line-height: 1.8;">
                At Evergreen Livestock, we specialize in raising healthy and organically fed livestock. Our animals are raised with care in a natural environment, ensuring they are strong and healthy. 
            </p>
        </div>
        <div style="border-radius: 30px; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.15);">
            <img src="/images/hero_banner.png" alt="Farm" class="breathe-anim" style="width: 100%; height: 100%; object-fit: cover; display: block;">
        </div>
    </div>
</section>



<%- include('../partials/footer') %>
