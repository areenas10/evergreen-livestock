<%- include('../partials/header') %>

<div class="container" style="min-height: 80vh; margin-top: 3rem;">
    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 3rem;">
        <h1 class="reveal" style="font-size: 2.5rem; font-weight: 800; color: var(--primary-green); letter-spacing: -1px;">User Portal</h1>
        <div class="reveal" style="padding: 0.5rem 1.2rem; background: var(--accent-lime); color: var(--primary-green); border-radius: 100px; font-weight: 700; font-size: 0.85rem; animation-delay: 0.1s;">
            Welcome back, <%= user.name %>
        </div>
    </div>
    
    <div style="display: grid; grid-template-columns: 1fr 3fr; gap: 3rem;">
        <!-- Left: Profile & Menu -->
        <div class="reveal" style="animation-delay: 0.2s;">
            <div class="summary-card" style="padding: 2rem;">
                <div style="text-align: center; margin-bottom: 2rem;">
                    <div style="width: 80px; height: 80px; background: #e8f5e9; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 2.5rem;">👤</div>
                    <h3 style="color: var(--primary-green);"><%= user.name %></h3>
                    <p style="font-size: 0.9rem; color: var(--text-muted);"><%= user.email %></p>
                </div>
                
                <div style="display: flex; flex-direction: column; gap: 1rem;">
                    <a href="/products" class="btn btn-ripple" style="width: 100%; border-radius: 12px; font-size: 0.85rem;">Shop Now</a>
                    <a href="/user/checkout" class="btn btn-secondary btn-ripple" style="width: 100%; border-radius: 12px; font-size: 0.85rem;">View Cart</a>
                    <a href="/auth/logout" style="text-align: center; color: #ff5f5f; text-decoration: none; font-weight: 700; font-size: 0.9rem; margin-top: 1rem;">Logout Account</a>
                </div>
            </div>
        </div>
        
        <!-- Right: Activity & History -->
        <div class="reveal" style="animation-delay: 0.3s; display: flex; flex-direction: column; gap: 2.5rem;">
            
            <!-- Reservations / Orders -->
            <div class="checkout-module">
                <div class="checkout-module-header">
                    <span>📋 Order History</span>
                </div>
                <div class="checkout-module-body" style="padding: 0;">
                    <% if (orders && orders.length > 0) { %>
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Ref ID</th>
                                    <th>Reservation Date</th>
                                    <th>Selection Details</th>
                                    <th>Delivery</th>
                                    <th>Status</th>
                                    <th>Payment</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% orders.forEach(order => { %>
                                    <tr>
                                        <td><span style="font-weight: 800; color: var(--primary-green);"><%= order.orderId || order.id.substring(0,8) %></span></td>
                                        <td><%= new Date(order.createdAt || order.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                                        <td>
                                            <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 6px;">
                                                <div style="display: flex; -webkit-mask-image: linear-gradient(to right, black 70%, transparent 100%);">
                                                    <% order.items.forEach((item, idx) => { %>
                                                        <% if(idx < 3) { %>
                                                            <img src="<%= item.image %>" style="width: 35px; height: 35px; border-radius: 8px; object-fit: cover; border: 2px solid white; box-shadow: 0 2px 5px rgba(0,0,0,0.1); <%= idx > 0 ? 'margin-left: -15px' : '' %>">
                                                        <% } %>
                                                    <% }) %>
                                                    <% if(order.items.length > 3) { %>
                                                        <div style="width: 35px; height: 35px; border-radius: 8px; background: #eee; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 800; margin-left: -15px; border: 2px solid white;">+<%= order.items.length - 3 %></div>
                                                    <% } %>
                                                </div>
                                                <span style="font-weight: 700;">₹<%= parseFloat(order.total_amount).toFixed(0) %></span>
                                            </div>
                                            <div style="font-size: 0.75rem; color: var(--text-muted); line-height: 1.3;">
                                                <% order.items.forEach(item => { %>
                                                    <div style="margin-bottom: 2px;">
                                                        <%= item.quantity %>x <%= item.productId ? item.productId.name : 'Item' %>
                                                        <% if (item.selectedWeight) { %>
                                                            <span style="color: var(--primary-green); font-weight: 700;">(<%= item.selectedWeight %>)</span>
                                                        <% } %>
                                                    </div>
                                                <% }) %>
                                            </div>
                                        </td>
                                        <td style="font-size: 0.8rem; color: var(--text-muted);">
                                            <span style="font-weight: bold;"><%= order.delivery_method || 'N/A' %></span>
                                            <% if (order.address) { %>
                                                <div style="margin-top: 4px; line-height: 1.3;"><%= order.address %></div>
                                            <% } %>
                                            <% if (order.phone) { %>
                                                <div style="margin-top: 4px; line-height: 1.3; font-weight: 500;">📞 <%= order.phone %></div>
                                            <% } %>
                                        </td>
                                        <td>
                                            <%
                                                let uStatus = order.order_status;
                                                let uStatusStyle = 'background: #fff8e1; color: #ff8f00;'; // Pending
                                                let uEmoji = '⏳';
                                                if (uStatus === 'Processing') {
                                                    uStatusStyle = 'background: #e8f0fe; color: #3949ab;';
                                                    uEmoji = '🔄';
                                                } else if (uStatus === 'Confirmed') {
                                                    uStatusStyle = 'background: #e3f2fd; color: #1565c0;';
                                                    uEmoji = '✅';
                                                } else if (uStatus === 'Completed') {
                                                    uStatusStyle = 'background: #e8f5e9; color: #2e7d32;';
                                                    uEmoji = '🏁';
                                                } else if (uStatus === 'Cancelled') {
                                                    uStatusStyle = 'background: #fce4e4; color: #c62828;';
                                                    uEmoji = '✕';
                                                }
                                            %>
                                            <span style="<%= uStatusStyle %> padding: 0.4rem 0.8rem; border-radius: 100px; font-size: 0.75rem; font-weight: 800;">
                                                <%= uEmoji %> <%= uStatus === 'Pending' ? 'PROCESSING' : uStatus.toUpperCase() %>
                                            </span>
                                        </td>
                                        <td>
                                            <div style="font-weight: 700; font-size: 0.85rem; color: var(--primary-green); margin-bottom: 5px;">
                                                <%= order.payment_details && order.payment_details.method ? order.payment_details.method : 'N/A' %>
                                            </div>
                                            <% if (order.payment_status === 'Paid') { %>
                                                <span style="color: #2e7d32; font-weight: 800; font-size: 0.85rem;">✓ Paid</span>
                                            <% } else { %>
                                                <span style="background: #fff3e0; color: #e65100; padding: 0.3rem 0.6rem; border-radius: 100px; font-size: 0.7rem; font-weight: 800;">PENDING VERIFICATION</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <div style="padding: 4rem; text-align: center;">
                            <div style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.2;">🌾</div>
                            <h3>No Orders Yet</h3>
                            <p style="color: var(--text-muted); margin-top: 0.5rem;">Your order history will appear here once you make a selection.</p>
                        </div>
                    <% } %>
                </div>
            </div>

            </div>

        </div>
    </div>
</div>

<%- include('../partials/footer') %>
